### 2. CREATE CHANT (simple JSON - sans fichiers)
POST {{baseUrl}}/chants
Content-Type: application/json

{
  "title": "Amazing Grace",
  "category": "adoration",
  "tags": ["lent", "classique"],
  "isPublished": true
}

### 3. CREATE CHANT (multipart - nouveau format, sans voix fixes)
POST {{baseUrl}}/chants
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="coverImage"; filename="image.jpg"
Content-Type: image/jpeg

< ./yess.jpg
--boundary
Content-Disposition: form-data; name="audio"; filename="audio.ogg"
Content-Type: audio/ogg

< ./audio.ogg
--boundary
Content-Disposition: form-data; name="sheetMusic"; filename="partition.pdf"
Content-Type: application/pdf

< ./partition.pdf
--boundary
Content-Disposition: form-data; name="voices[0][name]"

soprano
--boundary
Content-Disposition: form-data; name="voices[0][file]"; filename="soprano.mp3"
Content-Type: audio/mpeg

< ./soprano.mp3
--boundary
Content-Disposition: form-data; name="voices[1][name]"

alto
--boundary
Content-Disposition: form-data; name="voices[1][file]"; filename="alto.mp3"
Content-Type: audio/mpeg

< ./alto.mp3
--boundary
Content-Disposition: form-data; name="title"

Yesu Azali
--boundary
Content-Disposition: form-data; name="category"

adoration
--boundary
Content-Disposition: form-data; name="tags[]"

lent
--boundary
Content-Disposition: form-data; name="tags[]"

classique
--boundary
Content-Disposition: form-data; name="isPublished"

true
--boundary--

### 4. GET ALL CHANTS
GET {{baseUrl}}/chants

### 5. FILTER CHANTS (category + tag + published)
GET {{baseUrl}}/chants?category=louange&tag=classique&isPublished=true

### 5bis. SEARCH CHANTS (text index: title + lyrics)
GET {{baseUrl}}/chants?search=grace

### 5ter. FILTER CHANTS (isActive)
GET {{baseUrl}}/chants?isActive=true

### 6. GET CHANT BY ID
GET {{baseUrl}}/chants/{{chantId}}

### 7. GET CHANT BY SLUG
GET {{baseUrl}}/chants/slug/amazing-grace

### 8. UPDATE CHANT (Simple JSON)
PATCH {{baseUrl}}/chants/{{chantId}}
Content-Type: application/json

{
  "category": "louange",
  "isPublished": false
}

### 9. UPDATE CHANT (multipart - remplace cover + audio + 1 voice + sheetMusic)
PATCH {{baseUrl}}/chants/{{chantId}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="coverImage"; filename="new-image.jpg"
Content-Type: image/jpeg

< ./new-image.jpg
--boundary
Content-Disposition: form-data; name="audio"; filename="new-audio.ogg"
Content-Type: audio/ogg

< ./new-audio.ogg
--boundary
Content-Disposition: form-data; name="sheetMusic"; filename="new-partition.pdf"
Content-Type: application/pdf

< ./new-partition.pdf
--boundary
Content-Disposition: form-data; name="voices[0][name]"

soprano
--boundary
Content-Disposition: form-data; name="voices[0][file]"; filename="new-soprano.mp3"
Content-Type: audio/mpeg

< ./new-soprano.mp3
--boundary
Content-Disposition: form-data; name="title"

Yesu Azali (Remix)
--boundary
Content-Disposition: form-data; name="category"

louange
--boundary
Content-Disposition: form-data; name="tags[]"

rapide
--boundary
Content-Disposition: form-data; name="tags[]"

chorale
--boundary
Content-Disposition: form-data; name="isPublished"

false
--boundary--

### 10. DELETE CHANT
DELETE {{baseUrl}}/chants/{{chantId}}